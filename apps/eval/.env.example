API_KEY=sk-...

AGENT_BASE_URL=https://api.openai.com/v1
AGENT_MODEL=gpt-4o

USER_BASE_URL=https://api.openai.com/v1
USER_MODEL=gpt-4o

# --- Transcript flywheel (acmebox-flywheel) ---
# The judge that grades production chat transcripts against policy.md. Use a
# strong instruction-following model that returns clean JSON (e.g. gpt-4o or an
# Anthropic OpenAI-compatible model). Pure reasoning models work too but need
# headroom — the judge already allows 2048 tokens. JUDGE_API_KEY falls back to
# API_KEY if unset.
JUDGE_BASE_URL=https://api.openai.com/v1
JUDGE_MODEL=gpt-4o
# JUDGE_API_KEY=sk-...

# Optional: the teacher that rewrites failed transcripts (Phase 2). Falls back to
# the JUDGE_* config when unset.
# TEACHER_BASE_URL=https://api.openai.com/v1
# TEACHER_MODEL=gpt-4o
# TEACHER_API_KEY=sk-...

# Optional: the author that invents synthetic scenarios (`acmebox-flywheel
# generate`) — a persona+goal for the Together USER_* customer to role-play
# against the Liquid AGENT_*. Use a strong instruction-following model. Falls back
# to the JUDGE_* config when unset.
# AUTHOR_BASE_URL=https://api.openai.com/v1
# AUTHOR_MODEL=gpt-4o
# AUTHOR_API_KEY=sk-...

# MongoDB where the web app stores chat transcripts. Defaults match
# docker-compose.yml; override only if your stack differs.
# MONGODB_URI=mongodb://mongo:mongo@localhost:27017/acmebox?authSource=admin
# MONGODB_DB=acmebox
