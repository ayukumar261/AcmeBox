# ---- Hugging Face (optional) ----
# LFM2.5 is open-license (not gated), so no token is required to pull weights.
# Set one only to lift anonymous HF download rate limits.
# HF_TOKEN=hf_...

# ---- Model / serving (vLLM, OpenAI-compatible) ----
BASE_MODEL=LiquidAI/LFM2.5-8B-A1B
SERVE_PORT=8000
# 8B-A1B MoE (~17GB bf16) just fits the L4's 23GB: keep the context modest and
# let vLLM claim most of the card. Drop MAX_MODEL_LEN if you hit CUDA OOM.
MAX_MODEL_LEN=16384
GPU_MEMORY_UTILIZATION=0.95
# vLLM's native LFM2/2.5 tool-call parser (works for the lfm2_moe MoE too).
TOOL_CALL_PARSER=lfm2

# ---- LoRA SFT (scripts/train.sh -> train/sft.py) — RUN ON A SEPARATE GPU POD ----
# Path to the JSONL from `acmebox-flywheel export` (copy it onto the pod first).
# DATASET=/data/sft.jsonl
# OUTPUT_DIR=adapters/adapter-v1
# Exported examples run ~8k tokens (policy + 35-tool catalog), so keep this high
# to avoid dropping examples; lower it only if you hit OOM.
TRAIN_MAX_SEQ_LEN=16384
TRAIN_EPOCHS=3
TRAIN_LR=2e-4
TRAIN_BATCH_SIZE=1
TRAIN_GRAD_ACCUM=8
# Attention-only LoRA: LFM2.5 MoE experts are fused nn.Parameters (not adaptable),
# and `out_proj` is the attention output name (NOT `o_proj`).
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,out_proj
# Set to 1 for QLoRA (4-bit base) if training on a smaller card.
# LOAD_IN_4BIT=1

# ---- Persistent training pod (scripts/train_remote.sh, fired by the flywheel loop) ----
# The flywheel loop ships each batch here and runs scripts/train.sh on trigger.
# TRAIN_POD_SSH=root@<pod-ip>            # or <podid>-xxxx@ssh.runpod.io (proxy form)
# TRAIN_POD_PORT=<ssh-port>             # only for the direct-TCP form
# TRAIN_POD_KEY=~/.ssh/id_ed25519_runpod
# TRAIN_POD_DIR=/workspace/AcmeBox
