meta {
  name: Resume Subscription
  type: http
  seq: 16
}

patch {
  url: {{baseUrl}}/subscriptions/{{subscriptionId}}
  body: json
  auth: none
}

body:json {
  {
    "status": "active"
  }
}

assert {
  res.status: eq 200
  res.body.status: eq active
}

tests {
  test("responds with 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("moves the subscription back to active", function () {
    expect(res.getBody().status).to.equal("active");
  });
}
