meta {
  name: Get Order By Id
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/orders/{{orderId}}
  auth: none
}

assert {
  res.status: eq 200
  res.body.status: eq pending
}

tests {
  test("responds with 200 and the canonical record", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().id).to.equal(bru.getVar("orderId"));
    expect(res.getBody().items.length).to.equal(2);
  });
}
