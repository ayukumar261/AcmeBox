meta {
  name: Setup Customer
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/customers
  body: json
  auth: none
}

body:json {
  {
    "email": "{{addrEmail}}",
    "firstName": "Grace",
    "lastName": "Hopper",
    "locale": "en-US",
    "timezone": "America/New_York",
    "country": "US"
  }
}

script:pre-request {
  // Self-contained: this folder owns its own customer so it can run on its own.
  bru.setVar("addrEmail", `addr-${Date.now()}@example.com`);
}

script:post-response {
  bru.setVar("addrCustomerId", res.getBody().id);
}

assert {
  res.status: eq 201
  res.body.addresses: isEmpty
}

tests {
  test("creates the fixture customer", function () {
    expect(res.getStatus()).to.equal(201);
    expect(res.getBody().id).to.match(/^cus_/);
  });

  test("starts with no addresses", function () {
    expect(res.getBody().addresses).to.be.an("array").that.is.empty;
    expect(res.getBody().defaultAddressId).to.equal(undefined);
  });
}
