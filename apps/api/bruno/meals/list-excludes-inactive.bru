meta {
  name: List Excludes Inactive
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/meals?isActive=true
  body: none
  auth: none
}

params:query {
  isActive: true
}

assert {
  res.status: eq 200
}

tests {
  test("responds with 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("the retired meal is absent from the active catalog", function () {
    const ids = res.getBody().map((m) => m.id);
    expect(ids).to.not.include(bru.getVar("retiredMealId"));
  });
}
