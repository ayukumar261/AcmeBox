{
  "name": "AcmeBox",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "predev": "docker compose up -d --wait && pnpm db:migrate",
    "dev": "turbo run dev",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @repo/api db:migrate",
    "db:seed": "pnpm --filter @repo/api db:seed",
    "db:reset": "docker compose down -v && docker compose up -d --wait && pnpm db:migrate",
    "db:ui": "docker compose up -d --wait pgweb && open http://localhost:${PGWEB_PORT:-8085}",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18"
  }
}
